# ========================
# Knowlytics Hub — Environment Variables
# Copy this file to .env.local and fill in your values
# ========================

# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:password@localhost:5432/knowlytics_hub"

# App
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_WHATSAPP_NUMBER="+201000000000"

# Paymob Payment Gateway (when ready)
PAYMOB_API_KEY=""
PAYMOB_INTEGRATION_ID=""
PAYMOB_IFRAME_ID=""
PAYMOB_HMAC_SECRET=""

# AI Chatbot - choose one
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""

# Email (Resend / Nodemailer)
RESEND_API_KEY=""
EMAIL_FROM="noreply@knowlyticshub.com"

# Analytics (optional)
NEXT_PUBLIC_GA_ID=""
